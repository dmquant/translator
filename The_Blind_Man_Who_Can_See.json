50864, 412, 257, 3314, 295, 10447, 1266, 2459, 9239, 633, 2167, 1150, 13, 51014], "temperature": 0.0, "avg_logprob": -0.06969186237880162, "compression_ratio": 1.638783269961977, "no_speech_prob": 0.016460563987493515}, {"id": 52, "seek": 18650, "start": 199.5, "end": 204.5, "text": " But conscious cognitive processing operates under an extreme evolutionary speed limit.", "tokens": [51014, 583, 6648, 15605, 9007, 22577, 833, 364, 8084, 27567, 3073, 4948, 13, 51264], "temperature": 0.0, "avg_logprob": -0.06969186237880162, "compression_ratio": 1.638783269961977, "no_speech_prob": 0.016460563987493515}, {"id": 53, "seek": 18650, "start": 204.5, "end": 208.5, "text": " Out of those millions of inputs, the conscious mind can only process", "tokens": [51264, 5925, 295, 729, 6803, 295, 15743, 11, 264, 6648, 1575, 393, 787, 1399, 51464], "temperature": 0.0, "avg_logprob": -0.06969186237880162, "compression_ratio": 1.638783269961977, "no_speech_prob": 0.016460563987493515}, {"id": 54, "seek": 18650, "start": 208.5, "end": 211.5, "text": " a meager 10 to 40 bits of information per second.", "tokens": [51464, 257, 385, 3557, 1266, 281, 3356, 9239, 295, 1589, 680, 1150, 13, 51614], "temperature": 0.0, "avg_logprob": -0.06969186237880162, "compression_ratio": 1.638783269961977, "no_speech_prob": 0.016460563987493515}, {"id": 55, "seek": 21150, "start": 212.5, "end": 216.5, "text": " That massive unconscious pathway utilizes those millions of bits.", "tokens": [50414, 663, 5994, 18900, 18590, 4976, 5660, 729, 6803, 295, 9239, 13, 50614], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 56, "seek": 21150, "start": 216.5, "end": 220.5, "text": " It handles real-time motor control and split-second spatial tracking", "tokens": [50614, 467, 18722, 957, 12, 3766, 5932, 1969, 293, 7472, 12, 27375, 23598, 11603, 50814], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 57, "seek": 21150, "start": 220.5, "end": 222.5, "text": " to ensure survival in complex environments.", "tokens": [50814, 281, 5586, 12559, 294, 3997, 12388, 13, 50914], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 58, "seek": 21150, "start": 222.5, "end": 226.5, "text": " The 10-bit conscious mind is simply too slow to keep you alive.", "tokens": [50914, 440, 1266, 12, 5260, 6648, 1575, 307, 2935, 886, 2964, 281, 1066, 291, 5465, 13, 51114], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 59, "seek": 21150, "start": 226.5, "end": 229.5, "text": " Physical survival requires your nervous system", "tokens": [51114, 31918, 12559, 7029, 428, 6296, 1185, 51264], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 60, "seek": 21150, "start": 229.5, "end": 233.5, "text": " to farm out the overwhelming complexity of reality to an unconscious supercomputer.", "tokens": [51264, 281, 5421, 484, 264, 13373, 14024, 295, 4103, 281, 364, 18900, 36708, 13, 51464], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 61, "seek": 21150, "start": 233.5, "end": 237.5, "text": " If we shift from physical anatomy to the flow of time,", "tokens": [51464, 759, 321, 5513, 490, 4001, 31566, 281, 264, 3095, 295, 565, 11, 51664], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 62, "seek": 21150, "start": 237.5, "end": 239.5, "text": " we can track exactly how this delay works,", "tokens": [51664, 321, 393, 2837, 2293, 577, 341, 8577, 1985, 11, 51764], "temperature": 0.0, "avg_logprob": -0.0563771495452294, "compression_ratio": 1.6411149825783973, "no_speech_prob": 0.05240332707762718}, {"id": 63, "seek": 23950, "start": 239.5, "end": 244.5, "text": " starting from the exact millisecond physical light hits the retina.", "tokens": [50364, 2891, 490, 264, 1900, 27940, 18882, 4001, 1442, 8664, 264, 1533, 1426, 13, 50614], "temperature": 0.0, "avg_logprob": -0.06424387972405617, "compression_ratio": 1.55859375, "no_speech_prob": 0.0020052960608154535}, {"id": 64, "seek": 23950, "start": 244.5, "end": 249.5, "text": " This graph maps the early pre-conscious window using high-density EEG.", "tokens": [50614, 639, 4295, 11317, 264, 2440, 659, 12, 19877, 4910, 1228, 1090, 12, 67, 6859, 33685, 38, 13, 50864], "temperature": 0.0, "avg_logprob": -0.06424387972405617, "compression_ratio": 1.55859375, "no_speech_prob": 0.0020052960608154535}, {"id": 65, "seek": 23950, "start": 249.5, "end": 253.5, "text": " EEG is a recording method that measures electrical activity on the scalp", "tokens": [50864, 33685, 38, 307, 257, 6613, 3170, 300, 8000, 12147, 5191, 322, 264, 31972, 51064], "temperature": 0.0, "avg_logprob": -0.06424387972405617, "compression_ratio": 1.55859375, "no_speech_prob": 0.0020052960608154535}, {"id": 66, "seek": 23950, "start": 253.5, "end": 256.5, "text": " to track how neurons communicate.", "tokens": [51064, 281, 2837, 577, 22027, 7890, 13, 51214], "temperature": 0.0, "avg_logprob": -0.06424387972405617, "compression_ratio": 1.55859375, "no_speech_prob": 0.0020052960608154535}, {"id": 67, "seek": 23950, "start": 256.5, "end": 259.5, "text": " Between 170 and 240 milliseconds,", "tokens": [51214, 18967, 27228, 293, 26837, 34184, 11, 51364], "temperature": 0.0, "avg_logprob": -0.06424387972405617, "compression_ratio": 1.55859375, "no_speech_prob": 0.0020052960608154535}, {"id": 68, "seek": 23950, "start": 259.5, "end": 263.5, "text": " there is a distinct spike where occipital networks actively accumulate", "tokens": [51364, 456, 307, 257, 10644, 21053, 689, 10409, 11371, 1686, 9590, 13022, 33384, 51564], "temperature": 0.0, "avg_logprob": -0.06424387972405617, "compression_ratio": 1.55859375, "no_speech_prob": 0.0020052960608154535}, {"id": 69, "seek": 23950, "start": 263.5, "end": 267.5, "text": " and decode raw visual data entirely in the dark.", "tokens": [51564, 293, 979, 1429, 8936, 5056, 1412, 7696, 294, 264, 2877, 13, 51764], "temperature": 0.0, "avg_logprob": -0.06424387972405617, "compression_ratio": 1.55859375, "no_speech_prob": 0.0020052960608154535}, {"id": 70, "seek": 26750, "start": 267.5, "end": 271.5, "text": " During this rapid phase, the unconscious brain perfectly preserves", "tokens": [50364, 6842, 341, 7558, 5574, 11, 264, 18900, 3567, 6239, 1183, 9054, 50564], "temperature": 0.0, "avg_logprob": -0.05021804173787435, "compression_ratio": 1.550561797752809, "no_speech_prob": 0.0005452600889839232}, {"id": 71, "seek": 26750, "start": 271.5, "end": 274.5, "text": " the chronological sequence of high fidelity data.", "tokens": [50564, 264, 19393, 4383, 8310, 295, 1090, 46404, 1412, 13, 50714], "temperature": 0.0, "avg_logprob": -0.05021804173787435, "compression_ratio": 1.550561797752809, "no_speech_prob": 0.0005452600889839232}, {"id": 72, "seek": 26750, "start": 274.5, "end": 278.5, "text": " Every rapid flash and subtle movement is meticulously catalogued.", "tokens": [50714, 2048, 7558, 7319, 293, 13743, 3963, 307, 41566, 25038, 19746, 5827, 13, 50914], "temperature": 0.0, "avg_logprob": -0.05021804173787435, "compression_ratio": 1.550561797752809, "no_speech_prob": 0.0005452600889839232}, {"id": 73, "seek": 26750, "start": 278.5, "end": 282.5, "text": " Conscious perception emerges much later in the temporal stream.", "tokens": [50914, 6923, 4139, 12860, 38965, 709, 1780, 294, 264, 30881, 4309, 13, 51114], "temperature": 0.0, "avg_logprob": -0.05021804173787435, "compression_ratio": 1.550561797752809, "no_speech_prob": 0.0005452600889839232}, {"id": 74, "seek": 26750, "start": 282.5, "end": 286.5, "text": " It heavily relies on that pre-processed data to generate a unified snapshot", "tokens": [51114, 467, 10950, 30910, 322, 300, 659, 12, 41075, 292, 1412, 281, 8460, 257, 26787, 30163, 51314], "temperature": 0.0, "avg_logprob": -0.05021804173787435, "compression_ratio": 1.550561797752809, "no_speech_prob": 0.0005452600889839232}, {"id": 75, "seek": 26750, "start": 286.5, "end": 289.5, "text": " between 400 and 600 milliseconds.", "tokens": [51314, 1296, 8423, 293, 11849, 34184, 13, 51464], "temperature": 0.0, "avg_logprob": -0.05021804173787435, "compression_ratio": 1.550561797752809, "no_speech_prob": 0.0005452600889839232}, {"id": 76, "seek": 26750, "start": 289.5, "end": 293.5, "text": " The feeling of seeing instantly is a biological illusion.", "tokens": [51464, 440, 2633, 295, 2577, 13518, 307, 257, 13910, 18854, 13, 51664], "temperature": 0.0, "avg_logprob": -0.05021804173787435, "compression_ratio": 1.550561797752809, "no_speech_prob": 0.0005452600889839232}, {"id": 77, "seek": 29350, "start": 293.5, "end": 299.5, "text": " Conscious reality is actually a delayed, heavily edited summary of the recent past.", "tokens": [50364, 6923, 4139, 4103, 307, 767, 257, 20268, 11, 10950, 23016, 12691, 295, 264, 5162, 1791, 13, 50664], "temperature": 0.0, "avg_logprob": -0.07455654144287109, "compression_ratio": 1.518987341772152, "no_speech_prob": 0.024734122678637505}, {"id": 78, "seek": 29350, "start": 299.5, "end": 305.5, "text": " This evidence frames consciousness as a late-stage, low-bandwidth executive supervisor.", "tokens": [50664, 639, 4467, 12083, 10081, 382, 257, 3469, 12, 17882, 11, 2295, 12, 4235, 21271, 10140, 24610, 13, 50964], "temperature": 0.0, "avg_logprob": -0.07455654144287109, "compression_ratio": 1.518987341772152, "no_speech_prob": 0.024734122678637505}, {"id": 79, "seek": 29350, "start": 305.5, "end": 310.5, "text": " Its evolutionary purpose is to filter out the massive deluge of sensory noise,", "tokens": [50964, 6953, 27567, 4334, 307, 281, 6608, 484, 264, 5994, 1103, 7181, 295, 27233, 5658, 11, 51214], "temperature": 0.0, "avg_logprob": -0.07455654144287109, "compression_ratio": 1.518987341772152, "no_speech_prob": 0.024734122678637505}, {"id": 80, "seek": 29350, "start": 310.5, "end": 316.5, "text": " so the organism can focus purely on high-level anomalies and long-term planning.", "tokens": [51214, 370, 264, 24128, 393, 1879, 17491, 322, 1090, 12, 12418, 24769, 48872, 293, 938, 12, 7039, 5038, 13, 51514], "temperature": 0.0, "avg_logprob": -0.07455654144287109, "compression_ratio": 1.518987341772152, "no_speech_prob": 0.024734122678637505}, {"id": 81, "seek": 29350, "start": 316.5, "end": 319.5, "text": " You exist in a dual reality.", "tokens": [51514, 509, 2514, 294, 257, 11848, 4103, 13, 51664], "temperature": 0.0, "avg_logprob": -0.07455654144287109, "compression_ratio": 1.518987341772152, "no_speech_prob": 0.024734122678637505}, {"id": 82, "seek": 31950, "start": 319.5, "end": 323.5, "text": " As you consciously focus your narrow bandwidth on a single task,", "tokens": [50364, 1018, 291, 32538, 1879, 428, 9432, 23647, 322, 257, 2167, 5633, 11, 50564], "temperature": 0.0, "avg_logprob": -0.07576862970987956, "compression_ratio": 1.6159695817490494, "no_speech_prob": 0.0055315797217190266}, {"id": 83, "seek": 31950, "start": 323.5, "end": 329.5, "text": " silent sub-cortical machinery is constantly tracking the physics of your entire surrounding environment.", "tokens": [50564, 12784, 1422, 12, 66, 477, 804, 27302, 307, 6460, 11603, 264, 10649, 295, 428, 2302, 11498, 2823, 13, 50864], "temperature": 0.0, "avg_logprob": -0.07576862970987956, "compression_ratio": 1.6159695817490494, "no_speech_prob": 0.0055315797217190266}, {"id": 84, "seek": 31950, "start": 329.5, "end": 333.5, "text": " This taxonomy maps the global neuronal workspace theory,", "tokens": [50864, 639, 3366, 23423, 11317, 264, 4338, 12087, 21523, 32706, 5261, 11, 51064], "temperature": 0.0, "avg_logprob": -0.07576862970987956, "compression_ratio": 1.6159695817490494, "no_speech_prob": 0.0055315797217190266}, {"id": 85, "seek": 31950, "start": 333.5, "end": 337.5, "text": " showing exactly how the brain gates this information.", "tokens": [51064, 4099, 2293, 577, 264, 3567, 19792, 341, 1589, 13, 51264], "temperature": 0.0, "avg_logprob": -0.07576862970987956, "compression_ratio": 1.6159695817490494, "no_speech_prob": 0.0055315797217190266}, {"id": 86, "seek": 31950, "start": 337.5, "end": 341.5, "text": " A stimulus only crosses the threshold into conscious broadcast", "tokens": [51264, 316, 21366, 787, 28467, 264, 14678, 666, 6648, 9975, 51464], "temperature": 0.0, "avg_logprob": -0.07576862970987956, "compression_ratio": 1.6159695817490494, "no_speech_prob": 0.0055315797217190266}, {"id": 87, "seek": 31950, "start": 341.5, "end": 346.5, "text": " when it has sufficient physical strength and receives focused top-down attention.", "tokens": [51464, 562, 309, 575, 11563, 4001, 3800, 293, 20717, 5178, 1192, 12, 5093, 3202, 13, 51714], "temperature": 0.0, "avg_logprob": -0.07576862970987956, "compression_ratio": 1.6159695817490494, "no_speech_prob": 0.0055315797217190266}, {"id": 88, "seek": 34650, "start": 346.5, "end": 349.5, "text": " Otherwise, it remains entirely subliminal.", "tokens": [50364, 10328, 11, 309, 7023, 7696, 1422, 4197, 2071, 13, 50514], "temperature": 0.0, "avg_logprob": -0.041836522660165465, "compression_ratio": 1.3974358974358974, "no_speech_prob": 0.01630864478647709}, {"id": 89, "seek": 34650, "start": 349.5, "end": 354.5, "text": " An ancient high-speed visual system is constantly operating in the background,", "tokens": [50514, 1107, 7832, 1090, 12, 22746, 5056, 1185, 307, 6460, 7447, 294, 264, 3678, 11, 50764], "temperature": 0.0, "avg_logprob": -0.041836522660165465, "compression_ratio": 1.3974358974358974, "no_speech_prob": 0.01630864478647709}, {"id": 90, "seek": 34650, "start": 354.5, "end": 358.5, "text": " keeping you alive, and you are completely blind to it.", "tokens": [50764, 5145, 291, 5465, 11, 293, 291, 366, 2584, 6865, 281, 309, 13, 50964], "temperature": 0.0, "avg_logprob": -0.041836522660165465, "compression_ratio": 1.3974358974358974, "no_speech_prob": 0.01630864478647709}, {"id": 91, "seek": 34650, "start": 358.5, "end": 361.5, "text": " You are always seeing more than you know.", "tokens": [50964, 509, 366, 1009, 2577, 544, 813, 291, 458, 13, 51114], "temperature": 0.0, "avg_logprob": -0.041836522660165465, "compression_ratio": 1.3974358974358974, "no_speech_prob": 0.01630864478647709}], "language": "en"}